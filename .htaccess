# ===============================
# Generic fallback: any remaining /pages/articles/<slug>/<slug>.html → /blog/<slug>/
# (Catches any old article URL not explicitly listed above; lowercases via the
#  rule itself is not possible in RewriteRule, so this assumes lowercase slugs.
#  All explicit-case exceptions above are already handled and matched first.)
# ===============================
RewriteRule ^pages/articles/([a-z0-9-]+)/\1\.html$ /blog/$1/ [R=301,L,NC]

# ===============================
# Generic fallback: any remaining /pages/services/<slug>.html → /services/<slug>/
# (excludes content-writing, which is handled above with a forced-lowercase target)
# ===============================
RewriteCond %{REQUEST_URI} !^/pages/services/[Cc]ontent[-]?writing\.html$
RewriteRule ^pages/services/([a-zA-Z0-9-]+)\.html$ /services/$1/ [R=301,L,NC]
