RewriteEngine On

# ===============================
# Force HTTPS + www → non-www
# ===============================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.benaan\.com [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ===============================
# Homepage / Static Top-Level Pages
# ===============================
Redirect 301 /pages/about/about.html https://benaan.com/about/
Redirect 301 /pages/contact/contact.html https://benaan.com/contact/
Redirect 301 /contact https://benaan.com/contact/
Redirect 301 /contact/contact.html https://benaan.com/contact/
Redirect 301 /about/about.html https://benaan.com/about/

# ===============================
# Services Section
# ===============================
Redirect 301 /pages/services/allServices.html https://benaan.com/services/
Redirect 301 /pages/services/statistical-analysis.html https://benaan.com/services/statistical-analysis/
Redirect 301 /pages/services/translation.html https://benaan.com/services/translation/
Redirect 301 /pages/services/training-packages.html https://benaan.com/services/training-packages/
Redirect 301 /pages/services/proofreading.html https://benaan.com/services/proofreading/
Redirect 301 /pages/services/Content-writing.html https://benaan.com/services/content-writing/
RewriteRule ^pages/services/content[-\s%20]*writing\.html$ /services/content-writing/ [R=301,L,NC]

# ===============================
# Articles Index → Blog Index
# ===============================
Redirect 301 /pages/articles/allarticles.html https://benaan.com/blog/

